# URL de l'API backend
# Production (Render) : https://gestionnetsysteme.onrender.com
# Local : http://localhost:8000
VITE_API_URL=http://localhost:8000

# Clé API Google Maps (carte Pointage + Zone de travail — position en direct)
# 1. https://console.cloud.google.com/apis/credentials → Créer des identifiants → Clé API
# 2. Activez "Maps JavaScript API" : https://console.cloud.google.com/apis/library/maps-backend.googleapis.com
# Sans clé : OpenStreetMap est utilisée (position en direct reste active).
VITE_GOOGLE_MAPS_API_KEY=votre_cle_api_google_maps

# Calendrier Google (dashboard technicien / commercial / pointage)
# Google Calendar → Paramètres du calendrier → Intégrer le calendrier → copier l'URL du iframe (src="...")
# Exemple : https://calendar.google.com/calendar/embed?src=xxx%40group.calendar.google.com&ctz=Africa%2FDakar
# VITE_GOOGLE_CALENDAR_EMBED_URL=
