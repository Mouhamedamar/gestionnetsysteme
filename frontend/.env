# Clé API Google Maps (carte Pointage + Zone de travail)
# 1. Allez sur https://console.cloud.google.com/apis/credentials
# 2. Créez un projet ou sélectionnez-en un
# 3. Cliquez sur "Créer des identifiants" > "Clé API"
# 4. Activez "Maps JavaScript API" : https://console.cloud.google.com/apis/library/maps-backend.googleapis.com
# 5. Collez la clé ci-dessous (sans espaces)
VITE_GOOGLE_MAPS_API_KEY=

# URL de l'API backend Django (port 8001 pour éviter les conflits)
VITE_API_URL=http://localhost:8001

# Calendrier Google (embed) — affiché sur les dashboards technicien / commercial / pointage
VITE_GOOGLE_CALENDAR_EMBED_URL=https://calendar.google.com/calendar/embed?src=mouhamedamar508%40gmail.com&ctz=Africa%2FAbidjan
